{
  "name": "git-merge-branch-to",
  "displayName": "Git Merge Branch To",
  "description": "",
  "version": "1.2.2",
  "publisher": "FlyAboveGrass",
  "repository": {
    "type": "git",
    "url": "https://github.com/FlyAboveGrass/git-merge-branch-to"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "icon": "images/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitMergeBranchTo.merge-branch-to",
        "title": "$(git-branch) 合并分支到",
        "icon": "$(git-branch)"
      }
    ],
    "configuration": {
      "title": "Git Merge Branch To",
      "properties": {
        "gitMergeBranchTo.branches": {
          "type": "array",
          "default": [],
          "description": "可以合并到哪些分支内？",
          "items": {
            "type": "string"
          }
        },
        "gitMergeBranchTo.deployConfig": {
          "type": "object",
          "description": "配置流水线的环境及其对应的webhooks地址",
          "default": {}
        },
        "gitMergeBranchTo.feishuId": {
          "type": "string",
          "description": "自己的飞书id，用于做机器人通知（选填）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package --allow-missing-repository --allow-star-activation --no-dependencies",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "package:local": "pnpm run compile && node scripts/package-local.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"scripts/**/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.88.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
